# =============================================================================
# VERCA — šablona proměnných prostředí (Vercel + lokální vercel dev + Supabase)
# Účty OAuth: po vytvoření projektu v Supabase spusťte SQL z db/supabase-auth-profiles.sql (tabulka profiles + RLS + trigger).
# =============================================================================
# Zkopírujte do .env a doplňte hodnoty. Skutečné tajné klíče jen v Vercel Dashboard
# nebo v lokálním .env (soubor .env je v .gitignore — nikdy necommitovat).
# Do statického HTML/JS nedávejte SERVICE_ROLE_KEY, databázová hesla ani Stripe secret.
#
# Aktuální Vercel nasazení (příklad): https://verca-omega.vercel.app
# PUBLIC_SITE_URL = pouze původ (https + host), bez cesty /index.html
# Na Vercelu může zůstat prázdné: /api/public-config použije https://$VERCEL_URL jako fallback.
# =============================================================================

# --- Veřejná adresa webu (redirecty, e-maily, Stripe success/cancel) ----------
PUBLIC_SITE_URL=https://verca-omega.vercel.app

# Checkout / Stripe redirect (upravte při vlastní doméně)
# Volitelné: když chybí, server použije PUBLIC_SITE_URL (nebo https://$VERCEL_URL) + /bylinny-atelier.html?checkout=…
CHECKOUT_SUCCESS_URL=https://verca-omega.vercel.app/bylinny-atelier.html?checkout=success
CHECKOUT_CANCEL_URL=https://verca-omega.vercel.app/bylinny-atelier.html?checkout=cancel

# --- Veřejná konfigurace e-shopu (čte /api/public-config + stránka ateliéru) -----
# Po přihlášení přes Supabase OAuth musí být přesná URL v Supabase → Authentication → URL Configuration → Redirect URLs
# Výchozí: PUBLIC_SITE_URL + /auth-callback.html
SUPABASE_AUTH_REDIRECT_URL=https://verca-omega.vercel.app/auth-callback.html

# Zapnutí tlačítka „Přihlásit přes Google“ na bylinny-atelier.html (true / false)
PUBLIC_GOOGLE_LOGIN_ENABLED=false

# --- Supabase (projekt: Settings → API + Database) -----------------------------
# URL projektu — např. https://abcdefghijklmnop.supabase.co
SUPABASE_URL=

# Anon key — může jít jen do omezeného kódu (budoucí klient); stále respektovat RLS
SUPABASE_ANON_KEY=
# Alias pro šablony Next.js — /api/public-config čte stejně NEXT_PUBLIC_SUPABASE_URL a
# NEXT_PUBLIC_SUPABASE_ANON_KEY nebo NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY (když chybí SUPABASE_*).

# Service role — POUZE server (Vercel api/*), nikdy prohlížeč
SUPABASE_SERVICE_ROLE_KEY=

# Přímé připojení Postgres (Session mode / port 5432) — migrace, DDL, některé admin nástroje
# Dashboard → Database → Connection string → URI (Direct)
SUPABASE_DB_PASSWORD=
# Nebo celý řetězec najednou (nahraďte [PASSWORD] a host z dashboardu):
# DATABASE_URL_DIRECT=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# Connection pooling (Transaction mode, port 6543) — vhodné pro serverless / vysoký počet spojení
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Obecné aliasy (používá některý ORM / nástroje)
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# JWT secret z Supabase (Settings → API → JWT Secret) — jen pokud ho server potřebuje pro ověření tokenů mimo oficiální SDK
# SUPABASE_JWT_SECRET=

# --- Google přihlášení --------------------------------------------------------
# Varianta A (doporučeno se Supabase): Google provider v Supabase Dashboard → Authentication → Providers.
#   Tam zadejte Client ID + Secret z Google Cloud Console; často nepotřebujete nic z toho v .env pro čistě Supabase flow.
#
# Varianta B (vlastní OAuth callback v api/auth/google/callback): OAuth 2.0 Client v Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Musí přesně odpovídat Authorized redirect URI v Google Console i v Supabase (pokud používáte obojí)
AUTH_CALLBACK_URL=https://verca-omega.vercel.app/api/auth/google/callback

# Vlastní session cookie (mimo Supabase) — dlouhý náhodný řetězec, min. 32 znaků
AUTH_JWT_SECRET=
AUTH_SESSION_COOKIE_NAME=verca_session

# --- Stripe (platby) — pouze server ------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Volitelné — pro budoucí Elements; Checkout redirect z /api/checkout ho nepotřebuje
STRIPE_PUBLISHABLE_KEY=
# Alias: NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY (čte /api/public-config)

# Price ID z Stripe Dashboard → Products → cena (např. price_xxx). Na serveru musí být v allowlistu.
STRIPE_TEST_PRICE_ID=

# Čárkami oddělené price_… (pro více produktů). Sloučí se s STRIPE_TEST_PRICE_ID pro validaci checkoutu.
STRIPE_ALLOWED_PRICE_IDS=

# Veřejný katalog pro e-shop UI: upravte JSON v api/store/products.json (slug, name, description, image, price).
# Do odpovědi GET /api/store/catalog se dostanou jen položky, jejichž price je v allowlistu výše.

# Webhook endpoint ve Stripe CLI nebo Dashboard: https://váš-web.vercel.app/api/webhooks/stripe
# Události: checkout.session.completed (min.)

# --- API / provoz ------------------------------------------------------------------
NODE_ENV=development
# LOG_LEVEL=debug

# --- Volitelné ---------------------------------------------------------------------
# SENTRY_DSN=
# VERCEL_URL se na Vercelu nastaví automaticky; pro lokál nechat prázdné
