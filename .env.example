# VERCA — example environment variables for serverless (Vercel).
# Copy to .env locally for `vercel dev` if needed. Set real values only in Vercel Dashboard → Settings → Environment Variables.
# Never commit .env or paste real secrets into client-side HTML/JS.

# --- Stripe (payments) — server-only ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...   # optional: only if used from minimal client code; price IDs still validated server-side

# --- Google OAuth (optional login) — server-only ---
# GOOGLE_CLIENT_ID=....apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...
# AUTH_CALLBACK_URL=https://your-domain.cz/api/auth/google/callback
# AUTH_JWT_SECRET=generate-long-random-string-min-32-chars
# AUTH_SESSION_COOKIE_NAME=verca_session

# --- Database (when wired) ---
# DATABASE_URL=postgresql://user:pass@host:5432/verca
# DATABASE_URL_UNPOOLED=...   # if provider recommends unpooled for migrations

# --- App URLs ---
# PUBLIC_SITE_URL=https://your-domain.cz
# CHECKOUT_SUCCESS_URL=https://your-domain.cz/bylinny-atelier.html?checkout=success
# CHECKOUT_CANCEL_URL=https://your-domain.cz/bylinny-atelier.html?checkout=cancel

# --- Operational (optional) ---
# LOG_LEVEL=info
# SENTRY_DSN=...   # if error monitoring is added later
